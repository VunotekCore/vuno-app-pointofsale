{
  "name": "vuno-app-pointofsale-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for vuno-app-pointofsale",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js",
    "prod": "node --env-file=.env.production src/server.js",
    "start": "node src/server.js",
    "lint": "standard --fix src/**/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@imagekit/nodejs": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.1",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^11.0.0",
    "standard": "^17.1.0"
  },
  "standard": {
    "globals": [
      "pool",
      "crypto",
      "jsPDF"
    ],
    "ignore": [
      "src/repository/**",
      "src/controllers/**",
      "src/models/inventory.model.js",
      "src/models/company-config.model.js",
      "src/models/items.model.js",
      "src/models/roles.model.js",
      "src/models/auth.model.js",
      "src/models/users.model.js",
      "src/models/sales.model.js",
      "src/models/customers.model.js",
      "src/router/*.js",
      "src/middleware/*.js",
      "src/utils/ticket.utils.js"
    ]
  }
}
